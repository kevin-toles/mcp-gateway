# Idle Timeout Configuration
# ==========================
#
# Default timeout: 10 minutes (600 seconds)
# Per-service overrides can be set via environment variables.
#
# Usage:
#   export MCP_GATEWAY_DEFAULT_IDLE_TIMEOUT=600
#   export SEMANTIC_SEARCH_IDLE_TIMEOUT=600
#   export CODE_ORCHESTRATOR_IDLE_TIMEOUT=600
#   ...
#
# Or set in .env file.

# ── Default Timeout ─────────────────────────────────────────────────────
# Applied to all services unless overridden below.
# 10 minutes = 600 seconds
MCP_GATEWAY_DEFAULT_IDLE_TIMEOUT=600

# ── Per-Service Timeouts ────────────────────────────────────────────────
# Python services (heavier memory) - 10 min
UNIFIED_SEARCH_IDLE_TIMEOUT=600
LLM_GATEWAY_IDLE_TIMEOUT=600
CODE_ORCHESTRATOR_IDLE_TIMEOUT=600
AI_AGENTS_IDLE_TIMEOUT=600
AUDIT_SERVICE_IDLE_TIMEOUT=600
CMS_IDLE_TIMEOUT=600

# Rust/C++ services (lightweight) - 15 min
UNIFIED_SEARCH_RS_IDLE_TIMEOUT=900
INFERENCE_SERVICE_IDLE_TIMEOUT=900

# AMVE - 10 min
AMVE_IDLE_TIMEOUT=600

# ── Health Check Configuration ─────────────────────────────────────────
# How often to check for idle services (seconds)
MCP_GATEWAY_IDLE_CHECK_INTERVAL=60

# Maximum time to wait for service to become healthy after restart (seconds)
MCP_GATEWAY_HEALTH_CHECK_TIMEOUT=10

# Health check polling interval (milliseconds)
MCP_GATEWAY_HEALTH_POLL_INTERVAL=100

# ── Auto-Restart Configuration ─────────────────────────────────────────
# Enable auto-restart on demand
MCP_GATEWAY_AUTO_RESTART_ENABLED=true

# Maximum number of restart attempts before giving up
MCP_GATEWAY_MAX_RESTART_ATTEMPTS=3

# Delay between restart attempts (seconds)
MCP_GATEWAY_RESTART_DELAY=1
